{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyResourcesWithoutTags",
      "Effect": "Deny",
      "Action": [
        "secretsmanager:CreateSecret",
        "elasticache:CreateCacheCluster",
        "elasticache:CreateServerlessCache",
        "lambda:CreateFunction",
        "eks:CreateCluster",
        "eks:CreateNodegroup",
        "ecs:CreateCluster",
        "ecs:CreateService",
        "rds:CreateDBCluster",
        "rds:CreateDBProxy",
        "rds:CreateGlobalCluster"
      ],
      "Resource": "*",
      "Condition": {
        "Null": {
          "aws:RequestTag/Project": "true",
          "aws:RequestTag/Environment": "true",
          "aws:RequestTag/CostCenter": "true",
          "aws:RequestTag/Application": "true"
        }
      }
    },
    {
      "Sid": "DenyCreateDBInstanceWithoutTagsExceptAutoscale",
      "Effect": "Deny",
      "Action": [
        "rds:CreateDBInstance"
      ],
      "Resource": "*",
      "Condition": {
        "Null": {
          "aws:RequestTag/Project": "true",
          "aws:RequestTag/Environment": "true",
          "aws:RequestTag/CostCenter": "true",
          "aws:RequestTag/Application": "true"
        },
        "StringNotLike": {
          "aws:PrincipalArn": [
            "arn:aws:iam::*:role/aws-service-role/rds.application-autoscaling.amazonaws.com/AWSServiceRoleForApplicationAutoScaling_RDSInstance"
          ]
        },
        "Bool": {
          "aws:ViaAWSService": "false"
        }
      }
    },
    {
      "Sid": "DenyModifyDBInstanceWithoutTagsExceptAutoscale",
      "Effect": "Deny",
      "Action": [
        "rds:ModifyDBInstance"
      ],
      "Resource": "*",
      "Condition": {
        "Null": {
          "aws:ResourceTag/Project": "true",
          "aws:ResourceTag/Environment": "true",
          "aws:ResourceTag/CostCenter": "true",
          "aws:ResourceTag/Application": "true"
        },
        "StringNotLike": {
          "aws:PrincipalArn": [
            "arn:aws:iam::*:role/aws-service-role/rds.application-autoscaling.amazonaws.com/AWSServiceRoleForApplicationAutoScaling_RDSInstance"
          ]
        },
        "Bool": {
          "aws:ViaAWSService": "false"
        }
      }
    },
    {
      "Sid": "DenyElastiCacheReplicationGroupWithoutTags",
      "Effect": "Deny",
      "Action": "elasticache:CreateReplicationGroup",
      "Resource": [
        "arn:aws:elasticache:*:*:replicationgroup:*"
      ],
      "Condition": {
        "Null": {
          "aws:RequestTag/Project": "true",
          "aws:RequestTag/Environment": "true",
          "aws:RequestTag/CostCenter": "true",
          "aws:RequestTag/Application": "true"
        }
      }
    },
    {
      "Sid": "DenyEc2WithoutTags",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances"
      ],
      "Resource": [
        "arn:aws:ec2:*:*:instance/*",
        "arn:aws:ec2:*:*:volume/*"
      ],
      "Condition": {
        "Null": {
          "aws:RequestTag/Project": "true",
          "aws:RequestTag/Environment": "true",
          "aws:RequestTag/CostCenter": "true",
          "aws:RequestTag/Application": "true"
        }
      }
    },
    {
      "Sid": "DenyDataResourcesWithoutTags",
      "Effect": "Deny",
      "Action": [
        "dynamodb:CreateTable",
        "elasticfilesystem:CreateFileSystem",
        "ec2:CreateVolume"
      ],
      "Resource": [
        "arn:aws:dynamodb:*:*:table/*",
        "arn:aws:elasticfilesystem:*:*:file-system/*",
        "arn:aws:ec2:*:*:volume/*"
      ],
      "Condition": {
        "Null": {
          "aws:RequestTag/Project": "true",
          "aws:RequestTag/Environment": "true",
          "aws:RequestTag/CostCenter": "true",
          "aws:RequestTag/Application": "true"
        }
      }
    }
  ]
}
